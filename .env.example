# Project Management Service Configuration

# Application
DEBUG=True
HOST=0.0.0.0
PORT=8005

# Database
DATABASE_URL=postgresql+asyncpg://projectmgmt:projectmgmt_password@localhost:5432/project_mgmt_db

# JWT (must match User Management Service)
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis (optional)
REDIS_URL=redis://localhost:6379/4

# External Services
USER_SERVICE_URL=http://localhost:8001
CRM_SERVICE_URL=http://localhost:8004
PROCUREMENT_SERVICE_URL=http://localhost:8006
FINANCE_SERVICE_URL=http://localhost:8003

# Currency
DEFAULT_CURRENCY=GHS

# Email Configuration - Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=noreply@yourdomain.com
MAILGUN_FROM_NAME=OneImperial ERP
